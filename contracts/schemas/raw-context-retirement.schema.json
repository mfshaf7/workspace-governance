{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "raw_context_retirement"],
  "properties": {
    "schema_version": { "const": 1 },
    "raw_context_retirement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "owner_repo",
        "implementation_repo",
        "defining_epic_ref",
        "inventory_feature_ref",
        "inventory_work_item_ref",
        "playbook_work_item_ref",
        "primary_operator_surface",
        "purpose",
        "default_retirement_policy",
        "states",
        "parity_requirements",
        "inventory_entries",
        "migration_playbooks",
        "denied_actions"
      ],
      "properties": {
        "owner_repo": { "type": "string", "minLength": 1 },
        "implementation_repo": { "type": "string", "minLength": 1 },
        "defining_epic_ref": { "$ref": "#/$defs/openprojectRef" },
        "inventory_feature_ref": { "$ref": "#/$defs/openprojectRef" },
        "inventory_work_item_ref": { "$ref": "#/$defs/openprojectRef" },
        "playbook_work_item_ref": { "$ref": "#/$defs/openprojectRef" },
        "primary_operator_surface": { "type": "string", "minLength": 1 },
        "purpose": { "type": "string", "minLength": 1 },
        "default_retirement_policy": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "legacy_fallback_after_retirement",
            "rollback_until_retired",
            "parity_before_removal",
            "raw_projection_default",
            "exception_rule"
          ],
          "properties": {
            "legacy_fallback_after_retirement": { "type": "string", "minLength": 1 },
            "rollback_until_retired": { "type": "string", "minLength": 1 },
            "parity_before_removal": { "type": "string", "minLength": 1 },
            "raw_projection_default": { "type": "string", "minLength": 1 },
            "exception_rule": { "type": "string", "minLength": 1 }
          }
        },
        "states": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["state", "description"],
            "properties": {
              "state": { "type": "string", "minLength": 1 },
              "description": { "type": "string", "minLength": 1 }
            }
          }
        },
        "parity_requirements": {
          "type": "object",
          "additionalProperties": false,
          "required": ["required_evidence", "denied_parity_claims"],
          "properties": {
            "required_evidence": { "$ref": "#/$defs/stringList" },
            "denied_parity_claims": { "$ref": "#/$defs/stringList" }
          }
        },
        "inventory_entries": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/inventoryEntry" }
        },
        "migration_playbooks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["playbook_id", "applies_to_states", "steps"],
            "properties": {
              "playbook_id": { "type": "string", "minLength": 1 },
              "applies_to_states": { "$ref": "#/$defs/stringList" },
              "steps": { "$ref": "#/$defs/stringList" }
            }
          }
        },
        "denied_actions": { "$ref": "#/$defs/stringList" }
      }
    }
  },
  "$defs": {
    "openprojectRef": {
      "type": "string",
      "pattern": "^openproject://work_packages/[0-9]+$"
    },
    "stringList": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "inventoryEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entry_id",
        "owner_repo",
        "covered_repos",
        "context_behavior_repo_ref",
        "source_classes",
        "current_raw_context_path",
        "current_risk",
        "target_cgg_path",
        "state",
        "next_action",
        "retirement_allowed",
        "rollback_requirement",
        "evidence_refs"
      ],
      "properties": {
        "entry_id": { "type": "string", "minLength": 1 },
        "owner_repo": { "type": "string", "minLength": 1 },
        "covered_repos": { "$ref": "#/$defs/stringList" },
        "context_behavior_repo_ref": { "type": "string", "minLength": 1 },
        "source_classes": { "$ref": "#/$defs/stringList" },
        "current_raw_context_path": { "type": "string", "minLength": 1 },
        "current_risk": { "type": "string", "minLength": 1 },
        "target_cgg_path": { "type": "string", "minLength": 1 },
        "state": { "type": "string", "minLength": 1 },
        "next_action": { "type": "string", "minLength": 1 },
        "retirement_allowed": { "type": "boolean" },
        "rollback_requirement": { "type": "string", "minLength": 1 },
        "evidence_refs": { "$ref": "#/$defs/stringList" }
      }
    }
  }
}
