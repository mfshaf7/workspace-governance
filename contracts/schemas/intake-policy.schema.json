{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schema_version",
    "workspace_inventory",
    "statuses",
    "governance_triggers",
    "ai_suggestions",
    "repos",
    "products",
    "components",
    "validation_behavior",
    "context_behavior"
  ],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "workspace_inventory": {
      "type": "object",
      "required": ["scan_workspace_root_git_repos", "allow_unclassified_git_repos"],
      "properties": {
        "scan_workspace_root_git_repos": { "type": "boolean" },
        "allow_unclassified_git_repos": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "statuses": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "governance_triggers": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "ai_suggestions": {
      "type": "object",
      "required": [
        "enabled",
        "governed_profile_registry",
        "governed_intake_assist_contract",
        "required_profile_status",
        "required_purposes",
        "require_human_approval"
      ],
      "properties": {
        "enabled": { "type": "boolean" },
        "governed_profile_registry": {
          "type": "object",
          "required": ["repo", "path"],
          "properties": {
            "repo": { "type": "string", "minLength": 1 },
            "path": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false
        },
        "governed_intake_assist_contract": {
          "type": "object",
          "required": ["repo", "path"],
          "properties": {
            "repo": { "type": "string", "minLength": 1 },
            "path": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false
        },
        "required_profile_status": { "type": "string", "minLength": 1 },
        "required_purposes": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "require_human_approval": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "repos": {
      "type": "object",
      "required": ["admitted_requires_physical_repo", "admitted_required_files"],
      "properties": {
        "admitted_requires_physical_repo": { "type": "boolean" },
        "admitted_required_files": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    },
    "products": {
      "type": "object",
      "required": ["require_owner_metadata_when_in_scope"],
      "properties": {
        "require_owner_metadata_when_in_scope": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "components": {
      "type": "object",
      "required": ["require_owner_metadata_when_in_scope"],
      "properties": {
        "require_owner_metadata_when_in_scope": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "validation_behavior": {
      "type": "object",
      "required": [
        "enabled",
        "defining_work_item_ref",
        "catalog_ref",
        "repos",
        "products",
        "components",
        "runtime_profiles",
        "allowed_postures",
        "allowed_graph_roles",
        "direct_invocation_postures",
        "require_catalog_refs_for_direct_invocation",
        "notes"
      ],
      "properties": {
        "enabled": { "type": "boolean" },
        "defining_work_item_ref": {
          "type": "string",
          "pattern": "^openproject://work_packages/[0-9]+$"
        },
        "catalog_ref": {
          "type": "object",
          "required": ["repo", "path"],
          "properties": {
            "repo": { "type": "string", "minLength": 1 },
            "path": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false
        },
        "repos": {
          "type": "object",
          "required": ["require_for_active", "require_for_in_scope_intake"],
          "properties": {
            "require_for_active": { "type": "boolean" },
            "require_for_in_scope_intake": { "type": "boolean" }
          },
          "additionalProperties": false
        },
        "products": {
          "type": "object",
          "required": ["require_for_active", "require_for_in_scope_intake"],
          "properties": {
            "require_for_active": { "type": "boolean" },
            "require_for_in_scope_intake": { "type": "boolean" }
          },
          "additionalProperties": false
        },
        "components": {
          "type": "object",
          "required": ["require_for_active", "require_for_in_scope_intake"],
          "properties": {
            "require_for_active": { "type": "boolean" },
            "require_for_in_scope_intake": { "type": "boolean" }
          },
          "additionalProperties": false
        },
        "runtime_profiles": {
          "type": "object",
          "required": ["require_for_registered"],
          "properties": {
            "require_for_registered": { "type": "boolean" }
          },
          "additionalProperties": false
        },
        "allowed_postures": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "allowed_graph_roles": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "direct_invocation_postures": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "require_catalog_refs_for_direct_invocation": { "type": "boolean" },
        "notes": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "context_behavior": {
      "type": "object",
      "required": [
        "enabled",
        "defining_work_item_ref",
        "contract_ref",
        "raw_context_retirement_ref",
        "repos",
        "products",
        "components",
        "runtime_profiles",
        "default_model_projection",
        "notes"
      ],
      "properties": {
        "enabled": { "type": "boolean" },
        "defining_work_item_ref": {
          "type": "string",
          "pattern": "^openproject://work_packages/[0-9]+$"
        },
        "contract_ref": {
          "type": "object",
          "required": ["repo", "path"],
          "properties": {
            "repo": { "type": "string", "minLength": 1 },
            "path": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false
        },
        "raw_context_retirement_ref": {
          "type": "object",
          "required": ["repo", "path"],
          "properties": {
            "repo": { "type": "string", "minLength": 1 },
            "path": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false
        },
        "repos": {
          "type": "object",
          "required": ["require_for_active", "require_for_in_scope_intake"],
          "properties": {
            "require_for_active": { "type": "boolean" },
            "require_for_in_scope_intake": { "type": "boolean" }
          },
          "additionalProperties": false
        },
        "products": {
          "type": "object",
          "required": ["require_source_owner_declarations"],
          "properties": {
            "require_source_owner_declarations": { "type": "boolean" }
          },
          "additionalProperties": false
        },
        "components": {
          "type": "object",
          "required": ["require_for_active_shared_runtime"],
          "properties": {
            "require_for_active_shared_runtime": { "type": "boolean" }
          },
          "additionalProperties": false
        },
        "runtime_profiles": {
          "type": "object",
          "required": ["require_context_projection_posture"],
          "properties": {
            "require_context_projection_posture": { "type": "boolean" }
          },
          "additionalProperties": false
        },
        "default_model_projection": { "type": "string", "minLength": 1 },
        "notes": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
