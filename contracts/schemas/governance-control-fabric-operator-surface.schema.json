{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "governance_control_fabric_operator_surface"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "governance_control_fabric_operator_surface": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "owner_repo",
        "runtime_repo",
        "foundation_ref",
        "parent_feature_ref",
        "defining_work_item_ref",
        "governance_surface_path",
        "runtime_primary_operator_surface_ref",
        "purpose",
        "authority_boundaries",
        "operator_workflow",
        "minimum_cli_surface",
        "minimum_api_surface",
        "record_contracts",
        "profiles",
        "default_decision_rules",
        "blocker_triggers",
        "escalation_paths",
        "denied_actions",
        "day_one_non_goals",
        "sequencing"
      ],
      "properties": {
        "owner_repo": {
          "type": "string",
          "minLength": 1
        },
        "runtime_repo": {
          "type": "string",
          "minLength": 1
        },
        "foundation_ref": {
          "type": "string",
          "minLength": 1
        },
        "parent_feature_ref": {
          "$ref": "#/$defs/openprojectRef"
        },
        "defining_work_item_ref": {
          "$ref": "#/$defs/openprojectRef"
        },
        "governance_surface_path": {
          "type": "string",
          "minLength": 1
        },
        "runtime_primary_operator_surface_ref": {
          "type": "string",
          "minLength": 1
        },
        "purpose": {
          "type": "string",
          "minLength": 1
        },
        "authority_boundaries": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/authorityBoundary"
          }
        },
        "operator_workflow": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "workflow_posture",
            "phases"
          ],
          "properties": {
            "workflow_posture": {
              "type": "string",
              "minLength": 1
            },
            "phases": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/workflowPhase"
              }
            }
          }
        },
        "minimum_cli_surface": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "binary",
            "default_output_mode",
            "commands"
          ],
          "properties": {
            "binary": {
              "type": "string",
              "minLength": 1
            },
            "default_output_mode": {
              "type": "string",
              "minLength": 1
            },
            "commands": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/cliCommand"
              }
            }
          }
        },
        "minimum_api_surface": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "service_posture",
            "endpoints"
          ],
          "properties": {
            "service_posture": {
              "type": "string",
              "minLength": 1
            },
            "endpoints": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/apiEndpoint"
              }
            }
          }
        },
        "record_contracts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/recordContract"
          }
        },
        "profiles": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/profile"
          }
        },
        "default_decision_rules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/decisionRule"
          }
        },
        "blocker_triggers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/blockerTrigger"
          }
        },
        "escalation_paths": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/escalationPath"
          }
        },
        "denied_actions": {
          "$ref": "#/$defs/stringList"
        },
        "day_one_non_goals": {
          "$ref": "#/$defs/stringList"
        },
        "sequencing": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "before_runtime_implementation",
            "implementation_authority_rule"
          ],
          "properties": {
            "before_runtime_implementation": {
              "$ref": "#/$defs/stringList"
            },
            "implementation_authority_rule": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  },
  "$defs": {
    "stringList": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "openprojectRef": {
      "type": "string",
      "pattern": "^openproject://work_packages/[0-9]+$"
    },
    "authorityBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repo",
        "owns",
        "control_fabric_behavior"
      ],
      "properties": {
        "repo": {
          "type": "string",
          "minLength": 1
        },
        "owns": {
          "type": "string",
          "minLength": 1
        },
        "control_fabric_behavior": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "workflowPhase": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "phase_id",
        "operator_goal",
        "entrypoint_ids",
        "produced_record_ids",
        "mutation_boundary"
      ],
      "properties": {
        "phase_id": {
          "type": "string",
          "minLength": 1
        },
        "operator_goal": {
          "type": "string",
          "minLength": 1
        },
        "entrypoint_ids": {
          "$ref": "#/$defs/stringList"
        },
        "produced_record_ids": {
          "$ref": "#/$defs/stringList"
        },
        "mutation_boundary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "cliCommand": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command_id",
        "syntax",
        "phase_id",
        "purpose",
        "output_contract",
        "mutates_authority"
      ],
      "properties": {
        "command_id": {
          "type": "string",
          "minLength": 1
        },
        "syntax": {
          "type": "string",
          "minLength": 1
        },
        "phase_id": {
          "type": "string",
          "minLength": 1
        },
        "purpose": {
          "type": "string",
          "minLength": 1
        },
        "output_contract": {
          "type": "string",
          "minLength": 1
        },
        "mutates_authority": {
          "type": "boolean"
        }
      }
    },
    "apiEndpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "endpoint_id",
        "method",
        "path",
        "phase_id",
        "purpose",
        "response_record_id",
        "mutates_authority"
      ],
      "properties": {
        "endpoint_id": {
          "type": "string",
          "minLength": 1
        },
        "method": {
          "type": "string",
          "enum": [
            "GET",
            "POST"
          ]
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "phase_id": {
          "type": "string",
          "minLength": 1
        },
        "purpose": {
          "type": "string",
          "minLength": 1
        },
        "response_record_id": {
          "type": "string",
          "minLength": 1
        },
        "mutates_authority": {
          "type": "boolean"
        }
      }
    },
    "recordContract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_id",
        "purpose",
        "minimum_fields"
      ],
      "properties": {
        "record_id": {
          "type": "string",
          "minLength": 1
        },
        "purpose": {
          "type": "string",
          "minLength": 1
        },
        "minimum_fields": {
          "$ref": "#/$defs/stringList"
        }
      }
    },
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile_id",
        "posture",
        "allowed_actions",
        "denied_actions"
      ],
      "properties": {
        "profile_id": {
          "type": "string",
          "minLength": 1
        },
        "posture": {
          "type": "string",
          "minLength": 1
        },
        "allowed_actions": {
          "$ref": "#/$defs/stringList"
        },
        "denied_actions": {
          "$ref": "#/$defs/stringList"
        }
      }
    },
    "decisionRule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_id",
        "behavior"
      ],
      "properties": {
        "rule_id": {
          "type": "string",
          "minLength": 1
        },
        "behavior": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "blockerTrigger": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trigger_id",
        "condition",
        "required_operator_action"
      ],
      "properties": {
        "trigger_id": {
          "type": "string",
          "minLength": 1
        },
        "condition": {
          "type": "string",
          "minLength": 1
        },
        "required_operator_action": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "escalationPath": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path_id",
        "target_system",
        "when_used",
        "record_required"
      ],
      "properties": {
        "path_id": {
          "type": "string",
          "minLength": 1
        },
        "target_system": {
          "type": "string",
          "minLength": 1
        },
        "when_used": {
          "type": "string",
          "minLength": 1
        },
        "record_required": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
