{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema_version", "dependency_types"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "dependency_types": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["description", "allow_target_lifecycle"],
        "properties": {
          "description": { "type": "string", "minLength": 1 },
          "allow_target_lifecycle": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
