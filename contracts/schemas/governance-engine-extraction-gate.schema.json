{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "governance_engine_extraction_gate"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "governance_engine_extraction_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "owner_repo",
        "foundation_ref",
        "shadow_parity_ref",
        "boundary_map_ref",
        "security_review_ref",
        "primary_surface_path",
        "extraction_decision",
        "hard_gate_checks",
        "extraction_need_signals",
        "extraction_non_goals",
        "bounded_runtime_readiness_prerequisites",
        "deferred_follow_on_refs"
      ],
      "properties": {
        "owner_repo": {
          "type": "string",
          "minLength": 1
        },
        "foundation_ref": {
          "type": "string",
          "minLength": 1
        },
        "shadow_parity_ref": {
          "type": "string",
          "minLength": 1
        },
        "boundary_map_ref": {
          "type": "string",
          "minLength": 1
        },
        "security_review_ref": {
          "type": "string",
          "minLength": 1
        },
        "primary_surface_path": {
          "type": "string",
          "minLength": 1
        },
        "extraction_decision": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "default_outcome",
            "approved_outcome",
            "hard_gate_mode",
            "extraction_need_signal_threshold",
            "decision_record_requirements"
          ],
          "properties": {
            "default_outcome": {
              "type": "string",
              "minLength": 1
            },
            "approved_outcome": {
              "type": "string",
              "minLength": 1
            },
            "hard_gate_mode": {
              "type": "string",
              "minLength": 1
            },
            "extraction_need_signal_threshold": {
              "type": "string",
              "minLength": 1
            },
            "decision_record_requirements": {
              "$ref": "#/$defs/stringList"
            }
          }
        },
        "hard_gate_checks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/thresholdCheck"
          }
        },
        "extraction_need_signals": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/thresholdSignal"
          }
        },
        "extraction_non_goals": {
          "$ref": "#/$defs/stringList"
        },
        "bounded_runtime_readiness_prerequisites": {
          "$ref": "#/$defs/stringList"
        },
        "deferred_follow_on_refs": {
          "$ref": "#/$defs/stringList"
        }
      }
    }
  },
  "$defs": {
    "stringList": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "thresholdCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gate_id",
        "threshold",
        "evidence_sources"
      ],
      "properties": {
        "gate_id": {
          "type": "string",
          "minLength": 1
        },
        "threshold": {
          "type": "string",
          "minLength": 1
        },
        "evidence_sources": {
          "$ref": "#/$defs/stringList"
        }
      }
    },
    "thresholdSignal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "signal_id",
        "threshold",
        "evidence_sources"
      ],
      "properties": {
        "signal_id": {
          "type": "string",
          "minLength": 1
        },
        "threshold": {
          "type": "string",
          "minLength": 1
        },
        "evidence_sources": {
          "$ref": "#/$defs/stringList"
        }
      }
    }
  }
}
