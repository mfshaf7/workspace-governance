{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schema_version",
    "lane",
    "lane_classes",
    "profile_lifecycle",
    "request_admission",
    "source_state",
    "runtime_state_models",
    "testing",
    "trigger_guidance",
    "runtime_lane_decision",
    "forbidden_targets",
    "live_miss_escalation",
    "required_actions",
    "required_handoff_artifacts",
    "required_session_fields"
  ],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "lane": {
      "type": "object",
      "required": [
        "id",
        "standard_owner",
        "runtime_owner",
        "delivery_model",
        "runtime_target",
        "governed_handoff_target"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "standard_owner": { "type": "string", "minLength": 1 },
        "runtime_owner": { "type": "string", "minLength": 1 },
        "delivery_model": { "type": "string", "minLength": 1 },
        "runtime_target": { "type": "string", "minLength": 1 },
        "governed_handoff_target": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "lane_classes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "purpose", "governed_runtime_evidence"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "purpose": { "type": "string", "minLength": 1 },
          "governed_runtime_evidence": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    },
    "profile_lifecycle": {
      "type": "object",
      "required": [
        "statuses",
        "implementation_statuses",
        "self_serve_statuses",
        "request_record_required",
        "build_admission_required_for",
        "platform_acceptance_required_for",
        "security_review_ref_required_when_flagged"
      ],
      "properties": {
        "statuses": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "implementation_statuses": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "self_serve_statuses": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "request_record_required": { "type": "boolean" },
        "build_admission_required_for": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "platform_acceptance_required_for": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "security_review_ref_required_when_flagged": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "request_admission": {
      "type": "object",
      "required": [
        "current_request_adapter",
        "required_request_fields",
        "activation_requirements",
        "build_admission_requirements",
        "persistent_request_requirements"
      ],
      "properties": {
        "current_request_adapter": {
          "type": "object",
          "required": ["system", "owner_repo", "target_ref"],
          "properties": {
            "system": { "type": "string", "minLength": 1 },
            "owner_repo": { "type": "string", "minLength": 1 },
            "target_ref": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false
        },
        "required_request_fields": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "activation_requirements": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "build_admission_requirements": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "persistent_request_requirements": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    },
    "source_state": {
      "type": "object",
      "required": [
        "allow_dirty_worktrees",
        "allow_local_only_commits",
        "allow_branch_inputs",
        "allow_worktree_path_overrides",
        "session_manifest_required"
      ],
      "properties": {
        "allow_dirty_worktrees": { "type": "boolean" },
        "allow_local_only_commits": { "type": "boolean" },
        "allow_branch_inputs": { "type": "boolean" },
        "allow_worktree_path_overrides": { "type": "boolean" },
        "session_manifest_required": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "runtime_state_models": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "testing": {
      "type": "object",
      "required": ["smoke"],
      "properties": {
        "smoke": {
          "type": "object",
          "required": ["allowed_mutation_modes", "persistent_profile_rule"],
          "properties": {
            "allowed_mutation_modes": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            },
            "persistent_profile_rule": {
              "type": "object",
              "required": [
                "mutation_mode_must_be",
                "mutating_smoke_requires_separate_disposable_profile"
              ],
              "properties": {
                "mutation_mode_must_be": { "type": "string", "minLength": 1 },
                "mutating_smoke_requires_separate_disposable_profile": {
                  "type": "boolean"
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "trigger_guidance": {
      "type": "object",
      "required": ["required", "recommended", "optional"],
      "properties": {
        "required": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "recommended": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "optional": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    },
    "runtime_lane_decision": {
      "type": "object",
      "required": [
        "required_for_new_repos",
        "decisions",
        "component_inventory_required_repo_classes",
        "dev_integration_required_repo_classes",
        "waiver_decisions",
        "waivers"
      ],
      "properties": {
        "required_for_new_repos": { "type": "boolean" },
        "decisions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "component_inventory_required_repo_classes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "dev_integration_required_repo_classes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "waiver_decisions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "waivers": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["repo", "decision", "reason", "review_due_on"],
            "properties": {
              "repo": { "type": "string", "minLength": 1 },
              "decision": { "type": "string", "minLength": 1 },
              "reason": { "type": "string", "minLength": 1 },
              "review_due_on": {
                "type": "string",
                "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "forbidden_targets": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "live_miss_escalation": {
      "type": "object",
      "required": [
        "owner_repo",
        "purpose",
        "return_to_dev_integration_when",
        "route_to_platform_or_backend_boundary_when",
        "governed_rehearsal_allowed_when",
        "required_record_fields"
      ],
      "properties": {
        "owner_repo": { "type": "string", "minLength": 1 },
        "purpose": { "type": "string", "minLength": 1 },
        "return_to_dev_integration_when": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "route_to_platform_or_backend_boundary_when": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "governed_rehearsal_allowed_when": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "required_record_fields": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "required_actions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "required_handoff_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "required_session_fields": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "additionalProperties": false
}
