{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema_version", "profiles"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "profiles": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": [
          "owner_repo",
          "summary",
          "profile_path",
          "runtime_owner",
          "security_owner",
          "shared_dependencies",
          "source_repos",
          "stage_handoff",
          "actions"
        ],
        "properties": {
          "owner_repo": { "type": "string", "minLength": 1 },
          "summary": { "type": "string", "minLength": 1 },
          "profile_path": { "type": "string", "minLength": 1 },
          "runtime_owner": { "type": "string", "minLength": 1 },
          "security_owner": { "type": "string", "minLength": 1 },
          "shared_dependencies": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "source_repos": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "stage_handoff": {
            "type": "object",
            "required": ["owner_repo", "governed_surface"],
            "properties": {
              "owner_repo": { "type": "string", "minLength": 1 },
              "governed_surface": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          },
          "actions": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
