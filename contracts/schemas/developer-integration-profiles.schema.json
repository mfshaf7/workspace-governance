{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema_version", "profiles"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "profiles": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": [
          "lifecycle",
          "owner_repo",
          "summary",
          "purpose",
          "profile_path",
          "runtime_owner",
          "security_owner",
          "requested_by",
          "requested_on",
          "request_record",
          "shared_dependencies",
          "source_repos",
          "stage_handoff",
          "actions"
        ],
        "properties": {
          "lifecycle": { "type": "string", "minLength": 1 },
          "owner_repo": { "type": "string", "minLength": 1 },
          "summary": { "type": "string", "minLength": 1 },
          "purpose": { "type": "string", "minLength": 1 },
          "profile_path": { "type": "string", "minLength": 1 },
          "runtime_owner": { "type": "string", "minLength": 1 },
          "security_owner": { "type": "string", "minLength": 1 },
          "requested_by": { "type": "string", "minLength": 1 },
          "requested_on": {
            "type": "string",
            "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
          },
          "request_record": {
            "type": "object",
            "required": ["system", "ref"],
            "properties": {
              "system": { "type": "string", "minLength": 1 },
              "ref": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          },
          "admission": {
            "type": "object",
            "required": [
              "approved_by",
              "approved_on",
              "platform_acceptance_ref",
              "security_review_required",
              "security_review_refs"
            ],
            "properties": {
              "approved_by": { "type": "string", "minLength": 1 },
              "approved_on": {
                "type": "string",
                "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
              },
              "platform_acceptance_ref": {
                "type": "string",
                "minLength": 1
              },
              "security_review_required": { "type": "boolean" },
              "security_review_refs": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["repo", "path"],
                  "properties": {
                    "repo": { "type": "string", "minLength": 1 },
                    "path": { "type": "string", "minLength": 1 }
                  },
                  "additionalProperties": false
                }
              }
            },
            "additionalProperties": false
          },
          "shared_dependencies": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "source_repos": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "stage_handoff": {
            "type": "object",
            "required": ["owner_repo", "governed_surface"],
            "properties": {
              "owner_repo": { "type": "string", "minLength": 1 },
              "governed_surface": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          },
          "actions": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
