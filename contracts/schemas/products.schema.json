{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema_version", "products"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "products": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": [
          "lifecycle",
          "platform_owner",
          "security_owner",
          "runtime_owner",
          "source_owners",
          "stage_supported",
          "governed_prod_promotion",
          "highest_real_endpoint"
        ],
        "properties": {
          "lifecycle": { "type": "string", "minLength": 1 },
          "platform_owner": { "type": "string", "minLength": 1 },
          "security_owner": { "type": "string", "minLength": 1 },
          "runtime_owner": { "type": "string", "minLength": 1 },
          "source_owners": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "stage_supported": { "type": "boolean" },
          "governed_prod_promotion": { "type": "boolean" },
          "highest_real_endpoint": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
