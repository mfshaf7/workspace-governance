{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "governance_engine_output_manifest"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "governance_engine_output_manifest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "owner_repo",
        "compatibility_controls",
        "emission_families"
      ],
      "properties": {
        "owner_repo": {
          "type": "string",
          "minLength": 1
        },
        "compatibility_controls": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "materialization_default",
            "wgcf_detection_mode",
            "require_explicit_family",
            "require_manifest_output_match",
            "require_check_before_write",
            "allowed_write_profiles",
            "denied_without_profile"
          ],
          "properties": {
            "materialization_default": {
              "type": "string",
              "minLength": 1
            },
            "wgcf_detection_mode": {
              "type": "string",
              "minLength": 1
            },
            "require_explicit_family": {
              "type": "boolean"
            },
            "require_manifest_output_match": {
              "type": "boolean"
            },
            "require_check_before_write": {
              "type": "boolean"
            },
            "allowed_write_profiles": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              },
              "uniqueItems": true
            },
            "denied_without_profile": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              },
              "uniqueItems": true
            }
          }
        },
        "emission_families": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "boundary",
              "source_layers",
              "emitter",
              "output_mode"
            ],
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "boundary": {
                "type": "string",
                "minLength": 1
              },
              "source_layers": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "emitter": {
                "type": "string",
                "minLength": 1
              },
              "output_mode": {
                "type": "string",
                "enum": [
                  "explicit",
                  "dynamic-from-registry"
                ]
              },
              "source_contract": {
                "type": "string",
                "minLength": 1
              },
              "managed_manifest_filename": {
                "type": "string",
                "minLength": 1
              },
              "target_root_default": {
                "type": "string",
                "minLength": 1
              },
              "emitted_path_template": {
                "type": "string",
                "minLength": 1
              },
              "outputs": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "id"
                  ],
                  "properties": {
                    "id": {
                      "type": "string",
                      "minLength": 1
                    },
                    "format": {
                      "type": "string",
                      "enum": [
                        "json",
                        "text",
                        "yaml"
                      ]
                    },
                    "source_path": {
                      "type": "string",
                      "minLength": 1
                    },
                    "emitted_path": {
                      "type": "string",
                      "minLength": 1
                    }
                  }
                }
              }
            },
            "allOf": [
              {
                "if": {
                  "properties": {
                    "output_mode": {
                      "const": "explicit"
                    }
                  },
                  "required": [
                    "output_mode"
                  ]
                },
                "then": {
                  "required": [
                    "outputs"
                  ]
                }
              },
              {
                "if": {
                  "properties": {
                    "output_mode": {
                      "const": "dynamic-from-registry"
                    }
                  },
                  "required": [
                    "output_mode"
                  ]
                },
                "then": {
                  "required": [
                    "source_contract",
                    "managed_manifest_filename",
                    "target_root_default",
                    "emitted_path_template"
                  ]
                }
              }
            ]
          }
        }
      }
    }
  }
}
