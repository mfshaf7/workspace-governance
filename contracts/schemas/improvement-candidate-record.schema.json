{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schema_version",
    "id",
    "title",
    "recorded_on",
    "owner_repo",
    "summary",
    "status",
    "source_type",
    "scope",
    "signals",
    "resolution",
    "follow_up"
  ],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "recorded_on": { "type": "string", "format": "date" },
    "owner_repo": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "regression_of": { "type": ["string", "null"] },
    "status": {
      "type": "string",
      "enum": ["new", "triaged", "accepted", "dismissed", "closed"]
    },
    "source_type": {
      "type": "string",
      "enum": ["conversation", "machine-audit", "manual", "review", "rehearsal"]
    },
    "scope": {
      "type": "object",
      "required": ["related_repos", "related_products", "related_components", "change_classes"],
      "properties": {
        "related_repos": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "related_products": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "related_components": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "change_classes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "signals": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "trigger", "failure_classes", "finding", "source_refs"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "trigger": { "type": "string", "minLength": 1 },
          "failure_classes": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "type": "string", "minLength": 1 }
          },
          "finding": { "type": "string", "minLength": 1 },
          "source_refs": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "additionalProperties": false
      }
    },
    "resolution": {
      "type": "object",
      "required": ["after_action_ref", "control_refs", "note"],
      "properties": {
        "after_action_ref": { "type": ["string", "null"] },
        "control_refs": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["type", "path", "owner_repo"],
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "validator",
                  "skill",
                  "contract",
                  "runbook",
                  "test",
                  "workflow",
                  "doc",
                  "adr",
                  "change-record",
                  "template",
                  "script"
                ]
              },
              "path": { "type": "string", "minLength": 1 },
              "owner_repo": { "type": "string", "minLength": 1 },
              "note": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "note": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "follow_up": {
      "type": "object",
      "required": ["owner_repo", "due_on", "note"],
      "properties": {
        "owner_repo": { "type": ["string", "null"] },
        "due_on": { "type": ["string", "null"], "format": "date" },
        "note": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
