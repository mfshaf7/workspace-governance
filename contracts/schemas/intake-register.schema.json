{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema_version", "repos", "products", "components"],
  "$defs": {
    "aiSuggestion": {
      "type": "object",
      "required": [
        "profile_id",
        "policy_status",
        "decision_id",
        "generated_at",
        "confidence",
        "caller_id",
        "invocation_path",
        "suggested_decision",
        "operator_decision",
        "acceptance_state",
        "accepted_by",
        "accepted_at",
        "audit_ref"
      ],
      "properties": {
        "profile_id": { "type": "string", "minLength": 1 },
        "policy_status": { "type": "string", "minLength": 1 },
        "decision_id": { "type": "string", "minLength": 1 },
        "generated_at": { "type": "string", "format": "date-time" },
        "confidence": { "type": "string", "enum": ["low", "medium", "high"] },
        "caller_id": { "type": "string", "minLength": 1 },
        "invocation_path": { "type": "string", "minLength": 1 },
        "suggested_decision": {
          "type": "string",
          "enum": ["out-of-scope", "proposed", "admitted"]
        },
        "operator_decision": {
          "type": "string",
          "enum": ["out-of-scope", "proposed", "admitted"]
        },
        "acceptance_state": {
          "type": "string",
          "enum": ["accepted", "overridden"]
        },
        "accepted_by": { "type": "string", "minLength": 1 },
        "accepted_at": { "type": "string", "format": "date-time" },
        "audit_ref": { "type": "string", "minLength": 1 },
        "override_reason": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "repoEntry": {
      "type": "object",
      "required": [
        "status",
        "decision_source",
        "repo_class",
        "requires_security_bindings",
        "security_owner",
        "notes"
      ],
      "properties": {
        "status": { "type": "string", "minLength": 1 },
        "decision_source": { "type": "string", "minLength": 1 },
        "repo_class": { "type": ["string", "null"] },
        "requires_security_bindings": { "type": ["boolean", "null"] },
        "security_owner": { "type": ["string", "null"] },
        "notes": { "type": "string", "minLength": 1 },
        "validation_behavior": { "$ref": "#/$defs/validationBehavior" },
        "ai_suggestion": { "$ref": "#/$defs/aiSuggestion" }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "decision_source": { "const": "ai-suggested" }
            }
          },
          "then": {
            "required": ["ai_suggestion"]
          }
        }
      ],
      "additionalProperties": false
    },
    "productEntry": {
      "type": "object",
      "required": [
        "status",
        "decision_source",
        "platform_owner",
        "security_owner",
        "runtime_owner",
        "source_owners",
        "intended_endpoint",
        "notes"
      ],
      "properties": {
        "status": { "type": "string", "minLength": 1 },
        "decision_source": { "type": "string", "minLength": 1 },
        "platform_owner": { "type": ["string", "null"] },
        "security_owner": { "type": ["string", "null"] },
        "runtime_owner": { "type": ["string", "null"] },
        "source_owners": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "intended_endpoint": { "type": ["string", "null"] },
        "notes": { "type": "string", "minLength": 1 },
        "ai_suggestion": { "$ref": "#/$defs/aiSuggestion" }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "decision_source": { "const": "ai-suggested" }
            }
          },
          "then": {
            "required": ["ai_suggestion"]
          }
        }
      ],
      "additionalProperties": false
    },
    "componentEntry": {
      "type": "object",
      "required": [
        "status",
        "decision_source",
        "component_class",
        "owner_repo",
        "security_owner",
        "product",
        "notes"
      ],
      "properties": {
        "status": { "type": "string", "minLength": 1 },
        "decision_source": { "type": "string", "minLength": 1 },
        "component_class": { "type": ["string", "null"] },
        "owner_repo": { "type": ["string", "null"] },
        "security_owner": { "type": ["string", "null"] },
        "product": { "type": ["string", "null"] },
        "notes": { "type": "string", "minLength": 1 },
        "validation_behavior": { "$ref": "#/$defs/validationBehavior" },
        "ai_suggestion": { "$ref": "#/$defs/aiSuggestion" }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "decision_source": { "const": "ai-suggested" }
            }
          },
          "then": {
            "required": ["ai_suggestion"]
          }
        }
      ],
      "additionalProperties": false
    },
    "validationBehavior": {
      "type": "object",
      "required": ["posture", "wgcf_graph_role", "catalog_refs", "notes"],
      "properties": {
        "posture": { "type": "string", "minLength": 1 },
        "wgcf_graph_role": { "type": "string", "minLength": 1 },
        "catalog_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "notes": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  },
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "repos": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/repoEntry"
      }
    },
    "products": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/productEntry"
      }
    },
    "components": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/componentEntry"
      }
    }
  },
  "additionalProperties": false
}
