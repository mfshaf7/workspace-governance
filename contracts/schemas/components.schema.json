{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema_version", "components"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "components": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["lifecycle", "component_class", "owner_repo", "product", "security_owner", "validation_behavior"],
        "properties": {
          "lifecycle": { "type": "string", "minLength": 1 },
          "component_class": { "type": "string", "minLength": 1 },
          "owner_repo": { "type": "string", "minLength": 1 },
          "product": { "type": ["string", "null"] },
          "security_owner": { "type": "string", "minLength": 1 },
          "interface_contract": {
            "type": "object",
            "required": ["path", "validation_command"],
            "properties": {
              "path": { "type": "string", "minLength": 1 },
              "validation_command": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          },
          "validation_behavior": { "$ref": "#/$defs/validationBehavior" }
        },
        "additionalProperties": false
      }
    }
  },
  "$defs": {
    "validationBehavior": {
      "type": "object",
      "required": ["posture", "wgcf_graph_role", "catalog_refs", "notes"],
      "properties": {
        "posture": { "type": "string", "minLength": 1 },
        "wgcf_graph_role": { "type": "string", "minLength": 1 },
        "catalog_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "notes": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
