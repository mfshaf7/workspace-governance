{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schema_version",
    "id",
    "title",
    "recorded_on",
    "owner_repo",
    "summary",
    "scope",
    "source_refs",
    "lessons"
  ],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "recorded_on": { "type": "string", "format": "date" },
    "owner_repo": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "scope": {
      "type": "object",
      "required": ["related_repos", "related_products", "related_components", "change_classes"],
      "properties": {
        "related_repos": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "related_products": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "related_components": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "change_classes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "lessons": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "failure_class",
          "trigger",
          "finding",
          "impact",
          "status",
          "expected_control_types",
          "control_refs",
          "follow_up"
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "failure_class": { "type": "string", "minLength": 1 },
          "trigger": { "type": "string", "minLength": 1 },
          "finding": { "type": "string", "minLength": 1 },
          "impact": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "enum": ["open", "closed"] },
          "expected_control_types": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "enum": [
                "validator",
                "skill",
                "contract",
                "runbook",
                "test",
                "workflow",
                "doc",
                "adr",
                "change-record",
                "template",
                "script"
              ]
            }
          },
          "control_refs": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["type", "path", "owner_repo"],
              "properties": {
                "type": {
                  "type": "string",
                  "enum": [
                    "validator",
                    "skill",
                    "contract",
                    "runbook",
                    "test",
                    "workflow",
                    "doc",
                    "adr",
                    "change-record",
                    "template",
                    "script"
                  ]
                },
                "path": { "type": "string", "minLength": 1 },
                "owner_repo": { "type": "string", "minLength": 1 },
                "note": { "type": "string" }
              },
              "additionalProperties": false
            }
          },
          "follow_up": {
            "type": "object",
            "required": ["owner_repo", "due_on", "note"],
            "properties": {
              "owner_repo": { "type": ["string", "null"] },
              "due_on": { "type": ["string", "null"], "format": "date" },
              "note": { "type": ["string", "null"] }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
