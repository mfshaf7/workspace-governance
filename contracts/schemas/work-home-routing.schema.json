{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema_version", "work_home_routing"],
  "properties": {
    "schema_version": { "const": 1 },
    "work_home_routing": {
      "type": "object",
      "required": [
        "owner_repo",
        "purpose",
        "applies_to",
        "non_goals",
        "classification_order",
        "routing_homes",
        "classes",
        "evidence_relationship",
        "landing_and_review_policy",
        "reconciliation_policy",
        "examples"
      ],
      "properties": {
        "owner_repo": { "type": "string" },
        "purpose": { "type": "string", "minLength": 1 },
        "applies_to": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "non_goals": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "classification_order": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "routing_homes": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "object",
            "required": ["description", "system_of_record"],
            "properties": {
              "description": { "type": "string", "minLength": 1 },
              "system_of_record": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          }
        },
        "classes": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "object",
            "required": [
              "routing_home",
              "trigger",
              "required_action",
              "proportionality_rule"
            ],
            "properties": {
              "routing_home": { "type": "string", "minLength": 1 },
              "trigger": { "type": "string", "minLength": 1 },
              "required_action": { "type": "string", "minLength": 1 },
              "proportionality_rule": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          }
        },
        "evidence_relationship": {
          "type": "object",
          "required": [
            "art_record",
            "owner_repo_change_record",
            "landing_unit",
            "review_packet",
            "improvement_candidate",
            "handoff"
          ],
          "properties": {
            "art_record": { "type": "string", "minLength": 1 },
            "owner_repo_change_record": { "type": "string", "minLength": 1 },
            "landing_unit": { "type": "string", "minLength": 1 },
            "review_packet": { "type": "string", "minLength": 1 },
            "improvement_candidate": { "type": "string", "minLength": 1 },
            "handoff": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false
        },
        "landing_and_review_policy": {
          "type": "object",
          "required": [
            "purpose",
            "principles",
            "records",
            "landing_unit_decision_gate",
            "landing_unit_rules",
            "completion_rules",
            "exception_paths",
            "defect_handling",
            "parent_coverage_gate",
            "cleanup_policy"
          ],
          "properties": {
            "purpose": { "type": "string", "minLength": 1 },
            "principles": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            },
            "records": {
              "type": "object",
              "required": ["art_item", "landing_unit", "review_packet"],
              "properties": {
                "art_item": { "type": "string", "minLength": 1 },
                "landing_unit": { "type": "string", "minLength": 1 },
                "review_packet": { "type": "string", "minLength": 1 }
              },
              "additionalProperties": false
            },
            "landing_unit_decision_gate": {
              "type": "object",
              "required": [
                "purpose",
                "required_before",
                "decisions",
                "required_record",
                "default_rule"
              ],
              "properties": {
                "purpose": { "type": "string", "minLength": 1 },
                "required_before": {
                  "type": "array",
                  "minItems": 1,
                  "items": { "type": "string", "minLength": 1 }
                },
                "decisions": {
                  "type": "object",
                  "required": [
                    "feature_single_landing_unit",
                    "child_isolated_landing_unit",
                    "non_source_child",
                    "defer_decision_blocked"
                  ],
                  "properties": {
                    "feature_single_landing_unit": {
                      "type": "object",
                      "required": ["use_when", "effect"],
                      "properties": {
                        "use_when": { "type": "string", "minLength": 1 },
                        "effect": { "type": "string", "minLength": 1 }
                      },
                      "additionalProperties": false
                    },
                    "child_isolated_landing_unit": {
                      "type": "object",
                      "required": ["use_when", "required_reason", "effect"],
                      "properties": {
                        "use_when": { "type": "string", "minLength": 1 },
                        "required_reason": {
                          "type": "array",
                          "minItems": 1,
                          "items": { "type": "string", "minLength": 1 }
                        },
                        "effect": { "type": "string", "minLength": 1 }
                      },
                      "additionalProperties": false
                    },
                    "non_source_child": {
                      "type": "object",
                      "required": ["use_when", "effect"],
                      "properties": {
                        "use_when": { "type": "string", "minLength": 1 },
                        "effect": { "type": "string", "minLength": 1 }
                      },
                      "additionalProperties": false
                    },
                    "defer_decision_blocked": {
                      "type": "object",
                      "required": ["use_when", "effect"],
                      "properties": {
                        "use_when": { "type": "string", "minLength": 1 },
                        "effect": { "type": "string", "minLength": 1 }
                      },
                      "additionalProperties": false
                    }
                  },
                  "additionalProperties": false
                },
                "required_record": {
                  "type": "array",
                  "minItems": 1,
                  "items": { "type": "string", "minLength": 1 }
                },
                "default_rule": { "type": "string", "minLength": 1 }
              },
              "additionalProperties": false
            },
            "landing_unit_rules": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            },
            "completion_rules": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            },
            "exception_paths": {
              "type": "object",
              "minProperties": 1,
              "additionalProperties": {
                "type": "object",
                "required": ["use_when", "required_evidence"],
                "properties": {
                  "use_when": { "type": "string", "minLength": 1 },
                  "required_evidence": {
                    "type": "array",
                    "minItems": 1,
                    "items": { "type": "string", "minLength": 1 }
                  }
                },
                "additionalProperties": false
              }
            },
            "defect_handling": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            },
            "parent_coverage_gate": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            },
            "cleanup_policy": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            }
          },
          "additionalProperties": false
        },
        "reconciliation_policy": {
          "type": "object",
          "required": [
            "principles",
            "backfill_scope",
            "triggers",
            "resolution_paths",
            "required_decision_record",
            "forbidden_outcomes"
          ],
          "properties": {
            "principles": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            },
            "backfill_scope": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            },
            "triggers": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            },
            "resolution_paths": {
              "type": "object",
              "minProperties": 1,
              "additionalProperties": {
                "type": "object",
                "required": ["description", "use_when", "required_evidence"],
                "properties": {
                  "description": { "type": "string", "minLength": 1 },
                  "use_when": { "type": "string", "minLength": 1 },
                  "required_evidence": {
                    "type": "array",
                    "minItems": 1,
                    "items": { "type": "string", "minLength": 1 }
                  }
                },
                "additionalProperties": false
              }
            },
            "required_decision_record": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            },
            "forbidden_outcomes": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            }
          },
          "additionalProperties": false
        },
        "examples": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["scenario", "class", "owner_repo", "result"],
            "properties": {
              "scenario": { "type": "string", "minLength": 1 },
              "class": { "type": "string", "minLength": 1 },
              "owner_repo": { "type": "string", "minLength": 1 },
              "result": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
