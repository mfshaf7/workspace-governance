{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema_version", "repo", "lifecycle", "required_repo_refs", "required_patterns", "forbidden_patterns"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "repo": { "type": "string", "minLength": 1 },
    "lifecycle": { "type": "string", "minLength": 1 },
    "required_repo_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "required_patterns": {
      "type": "object",
      "required": ["readme", "agents"],
      "properties": {
        "readme": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "agents": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      },
      "additionalProperties": false
    },
    "forbidden_patterns": {
      "type": "object",
      "required": ["readme", "agents"],
      "properties": {
        "readme": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "agents": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      },
      "additionalProperties": false
    },
    "security_requirements": {
      "type": "object",
      "required": ["security_owner", "review_checklist_path", "review_output_path", "required_artifacts"],
      "properties": {
        "security_owner": { "type": "string", "minLength": 1 },
        "review_checklist_path": { "type": "string", "minLength": 1 },
        "review_output_path": { "type": "string", "minLength": 1 },
        "required_artifacts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "path", "review_areas", "required_in_docs"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "path": { "type": "string", "minLength": 1 },
              "review_areas": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "minLength": 1 }
              },
              "required_in_docs": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "enum": ["readme", "agents"]
                }
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "security_change_record_requirements": {
      "type": "object",
      "required": [
        "change_record_readme_path",
        "policy_path",
        "validator_script_path",
        "workflow_path",
        "pr_template_path",
        "required_in_docs"
      ],
      "properties": {
        "change_record_readme_path": { "type": "string", "minLength": 1 },
        "policy_path": { "type": "string", "minLength": 1 },
        "validator_script_path": { "type": "string", "minLength": 1 },
        "workflow_path": { "type": "string", "minLength": 1 },
        "pr_template_path": { "type": "string", "minLength": 1 },
        "required_in_docs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": ["readme", "agents"]
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
