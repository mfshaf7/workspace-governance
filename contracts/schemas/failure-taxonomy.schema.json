{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema_version", "failure_classes"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "failure_classes": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["description", "recommended_control_types"],
        "properties": {
          "description": { "type": "string", "minLength": 1 },
          "recommended_control_types": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "enum": [
                "validator",
                "skill",
                "contract",
                "runbook",
                "test",
                "workflow",
                "doc",
                "adr",
                "change-record",
                "template",
                "script"
              ]
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
