{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schema_version",
    "delegation_id",
    "created_on",
    "owner_repo",
    "work_item_ref",
    "task_class",
    "summary",
    "main_agent",
    "packets",
    "integration_outcome"
  ],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "delegation_id": { "type": "string", "minLength": 1 },
    "created_on": { "type": "string", "format": "date" },
    "owner_repo": { "type": "string", "minLength": 1 },
    "work_item_ref": { "type": "string", "minLength": 1 },
    "task_class": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "main_agent": {
      "type": "object",
      "required": ["authority_owner", "retained_actions"],
      "properties": {
        "authority_owner": { "type": "string", "minLength": 1 },
        "retained_actions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    },
    "packets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "packet_id",
          "delegate_kind",
          "target_repo",
          "task_summary",
          "allowed_write_paths",
          "expected_outputs",
          "proof_expectation",
          "forbidden_actions",
          "status",
          "changed_paths",
          "uncovered_work"
        ],
        "properties": {
          "packet_id": { "type": "string", "minLength": 1 },
          "delegate_kind": {
            "type": "string",
            "enum": ["exploration", "implementation", "verification"]
          },
          "tool_role": { "type": ["string", "null"] },
          "delegate_agent_id": { "type": ["string", "null"] },
          "target_repo": { "type": "string", "minLength": 1 },
          "task_summary": { "type": "string", "minLength": 1 },
          "allowed_write_paths": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          },
          "expected_outputs": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "proof_expectation": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "forbidden_actions": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "type": "string", "minLength": 1 }
          },
          "status": {
            "type": "string",
            "enum": ["assigned", "in-progress", "completed", "integrated", "rejected"]
          },
          "changed_paths": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          },
          "uncovered_work": {
            "type": "object",
            "required": ["classification", "note"],
            "properties": {
              "classification": {
                "type": "string",
                "enum": [
                  "none",
                  "absorbed-into-active-item",
                  "new-work-record",
                  "routed-elsewhere"
                ]
              },
              "note": { "type": ["string", "null"] }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    "integration_outcome": {
      "type": "object",
      "required": ["status", "integrated_by", "security_review_ref", "evidence_refs"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["integrated", "partially-integrated", "rejected"]
        },
        "integrated_by": { "type": "string", "minLength": 1 },
        "security_review_ref": { "type": ["string", "null"] },
        "evidence_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "note": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
